class Solution:
    def movesToStamp(self, stamp: str, target: str):
        target = list(target)
        stamp = list(stamp)
        
        n, m = len(target), len(stamp)
        res = []
        visited = [False] * (n - m + 1)
        total_replaced = 0
        
        def can_stamp(i):
            replaced = False
            for j in range(m):
                if target[i+j] == '?':
                    continue
                if target[i+j] != stamp[j]:
                    return False
                replaced = True
            return replaced
        
        def do_stamp(i):
            nonlocal total_replaced
            for j in range(m):
                if target[i+j] != '?':
                    target[i+j] = '?'
                    total_replaced += 1
        
        while total_replaced < n:
            changed = False
            
            for i in range(n - m + 1):
                if not visited[i] and can_stamp(i):
                    do_stamp(i)
                    visited[i] = True
                    res.append(i)
                    changed = True
                    
                    if total_replaced == n:
                        break
            
            if not changed:
                return []
        
        return res[::-1]
